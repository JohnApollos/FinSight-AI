# Google Gemini API Key (Get a free one from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# LLM model configuration
GEMINI_MODEL=gemini-1.5-flash

# Telemetry and Logging (MLflow logs locally to a SQLite database)
MLFLOW_TRACKING_URI=sqlite:///backend/data/mlflow.db

# Vector store storage path
CHROMA_DB_PATH=backend/data/chroma

# SEC EDGAR Downloader Compliance User-Agent (Format: Name email@domain.com)
SEC_USER_AGENT=FinLensAI-DevUser student_dev@finlensai.local

# Server Host and Port configurations
HOST=127.0.0.1
PORT=8000
